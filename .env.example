# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
MONGODB_URI=mongodb://mongo:27017/chatbot

# --- AI Provider ---
# Set to "gemini", "openai", or "openrouter". Only the matching keys below are required.
AI_PROVIDER=openrouter

# --- Gemini (used when AI_PROVIDER=gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (used when AI_PROVIDER=openai) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- OpenRouter (used when AI_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
